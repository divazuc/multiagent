    {
      "id": "97d24856-b028-4b2c-9e44-1057b2e765e0",
      "typeVersion": 2,
      "position": [
        700,
        200
      ],
      "name": "Run validation checks",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst response = data.candidate_response || '';\nconst guardrails = data.guardrails || {};\nconst persona = data.persona || {};\n\nconst issues = [];\n\n// 1. Length check — must not be excessively long\nconst wordCount = response.trim().split(/\\s+/).length;\nif (wordCount > 80) issues.push('too_long');\n\n// 2. Single-question rule — must not contain more than one question mark\nconst questionMarks = (response.match(/\\?/g) || []).length;\nif (questionMarks > 1) issues.push('multiple_questions');\n\n// 3. Forward motion — must not end with a period and no question/CTA signal\nconst hasForwardMotion = /\\?|!|book|call|schedule|contact|send|share|let me know|אשמח|בוא|קבע|שלח/i.test(response);\nif (!hasForwardMotion && wordCount > 10) issues.push('no_forward_motion');\n\n// 4. Guardrail check — forbidden phrases\nconst forbidden = guardrails.forbidden_phrases || [];\nfor (const phrase of forbidden) {\n  if (response.toLowerCase().includes(phrase.toLowerCase())) {\n    issues.push('guardrail_violation');\n    break;\n  }\n}\n\n// 5. Generic AI language check\nconst genericPhrases = ['certainly', 'of course', 'absolutely', 'as an ai', 'i am an ai', 'i cannot', 'i do not have the ability'];\nfor (const phrase of genericPhrases) {\n  if (response.toLowerCase().includes(phrase)) {\n    issues.push('sounds_generic');\n    break;\n  }\n}\n\nconst validation_passed = issues.length === 0;\n\nreturn [{ json: {\n  ...data,\n  validation_passed,\n  validation_issues: issues\n} }];"
      }
    },
    {
      "id": "a689a5c5-6a56-4e7f-b489-f19a820cb379",
      "typeVersion": 2,
      "position": [
        1000,
        200
      ],
      "name": "Passed validation?",
      "type": "n8n-nodes-base.if",
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.validation_passed }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "93b4acd6-d725-45b2-8433-1d9d92ba5dad",
      "typeVersion": 2,
      "position": [
        1300,
        200
      ],
      "name": "Check retry limit",
      "type": "n8n-nodes-base.if",
      "parameters": {
        "conditions": {
          "options": {
