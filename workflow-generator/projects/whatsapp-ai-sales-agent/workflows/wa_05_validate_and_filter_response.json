            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.retry_count }}",
              "rightValue": 2,
              "operator": {
                "type": "number",
                "operation": "lt"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "5e7a2be2-9994-440c-9d61-73cedb7938cc",
      "typeVersion": 3.4,
      "position": [
        1600,
        200
      ],
      "name": "Build rewrite prompt",
      "type": "n8n-nodes-base.set",
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "rewrite_prompt",
              "value": "=You are a strict response editor for a conversational sales agent.\n\nThe following candidate response FAILED these quality checks:\n{{ $json.validation_issues.join(', ') }}\n\nFailed response:\n\"{{ $json.candidate_response }}\"\n\nPersona tone: {{ JSON.stringify($json.persona.tone ?? 'natural, direct') }}\nLanguage: {{ $json.language }}\nNext stage: {{ $json.next_stage }}\nCTA triggered: {{ $json.cta_triggered }}\nHebrew patterns (if applicable): {{ JSON.stringify($json.hebrew_patterns) }}\nGuardrails - forbidden: {{ JSON.stringify($json.guardrails.forbidden_phrases ?? []) }}\n\nRewrite rules (MANDATORY):\n- Maximum 60 words\n- Only ONE question if needed\n- Must move conversation forward (CTA or qualifying question)\n- Must match the persona tone exactly\n- Must NOT sound like AI — sound like the business owner\n- No generic phrases (certainly, of course, absolutely, as an AI)\n- Do NOT invent business information\n- Respect all guardrail constraints\n- If language is 'he', respond in Hebrew\n\nReturn ONLY the rewritten response text. No explanation. No quotes. No prefix.",
              "type": "string"
            },
            {
              "name": "retry_count",
              "value": "={{ ($json.retry_count ?? 0) + 1 }}",
              "type": "number"
            }
          ]
        }
      }
    },
    {
      "id": "31b8d47c-ed69-4a5c-8fe4-13ad678c56fc",
      "typeVersion": 4.2,
      "position": [
        1900,
        200
      ],
      "name": "Rewrite via Claude",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "credentials": {
          "httpHeaderAuth": {
            "id": "O6dnMJBEHEOipCdX",
            "name": "ANTHROPIC_HTTP_HEADER_AUTH"
          }
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 300,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify($json.rewrite_prompt) }}\n    }\n  ]\n}",
        "continueOnFail": true
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "O6dnMJBEHEOipCdX",
          "name": "ANTHROPIC_HTTP_HEADER_AUTH"
        }
      }
    },
    {
      "id": "b1661a2e-6d58-4510-9822-cf1342f3faea",
      "typeVersion": 2,
      "position": [
        2200,
        200
      ],
      "name": "Extract rewritten response",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst prev = $('Build rewrite prompt').first().json;\n\nlet rewritten = '';\ntry {\n  rewritten = input.content?.[0]?.text?.trim() || '';\n} catch(e) {\n  rewritten = '';\n}\n\nif (!rewritten) {\n  return [{ json: {\n    ...prev,\n    candidate_response: prev.candidate_response,\n    rewrite_failed: true,\n    rewrite_applied: false\n  } }];\n}\n\nreturn [{ json: {\n  ...prev,\n  candidate_response: rewritten,\n  rewrite_applied: true,\n  rewrite_failed: false,\n  validation_passed: false\n} }];"
      }
    },
    {
      "id": "d8ed89b9-d6f7-458b-8250-3f63790367b5",
      "typeVersion": 2,
      "position": [
        2500,
        200
      ],
      "name": "Re-run validation checks",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst response = data.candidate_response || '';\nconst guardrails = data.guardrails || {};\n\nconst issues = [];\n\nconst wordCount = response.trim().split(/\\s+/).length;\nif (wordCount > 80) issues.push('too_long');\n\nconst questionMarks = (response.match(/\\?/g) || []).length;\nif (questionMarks > 1) issues.push('multiple_questions');\n\nconst hasForwardMotion = /\\?|!|book|call|schedule|contact|send|share|let me know|אשמח|בוא|קבע|שלח/i.test(response);\nif (!hasForwardMotion && wordCount > 10) issues.push('no_forward_motion');\n\nconst forbidden = guardrails.forbidden_phrases || [];\nfor (const phrase of forbidden) {\n  if (response.toLowerCase().includes(phrase.toLowerCase())) {\n    issues.push('guardrail_violation');\n    break;\n  }\n}\n\nconst genericPhrases = ['certainly', 'of course', 'absolutely', 'as an ai', 'i am an ai', 'i cannot'];\nfor (const phrase of genericPhrases) {\n  if (response.toLowerCase().includes(phrase)) {\n    issues.push('sounds_generic');\n    break;\n  }\n}\n\nconst validation_passed = issues.length === 0;\n\nreturn [{ json: {\n  ...data,\n  validation_passed,\n  validation_issues: issues\n} }];"
      }
    },
