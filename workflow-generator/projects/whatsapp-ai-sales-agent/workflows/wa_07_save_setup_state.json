      "type": "n8n-nodes-base.postgres",
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO business_profiles (\n  business_id,\n  session_id,\n  business_model,\n  sales_goal,\n  conversation_strategy,\n  services,\n  persona,\n  guardrails,\n  hebrew_patterns,\n  setup_completed,\n  committed_at,\n  updated_at\n)\nVALUES (\n  '{{ $json.business_id }}',\n  '{{ $json.session_id }}',\n  '{{ $json.draft_setup_data?.business_model ?? null }}'::jsonb,\n  '{{ $json.draft_setup_data?.sales_goal ?? null }}'::text,\n  '{{ $json.draft_setup_data?.conversation_strategy ?? null }}'::text,\n  '{{ JSON.stringify($json.draft_setup_data?.services ?? []) }}'::jsonb,\n  '{{ JSON.stringify($json.draft_setup_data?.persona ?? {}) }}'::jsonb,\n  '{{ JSON.stringify($json.draft_setup_data?.guardrails ?? {}) }}'::jsonb,\n  '{{ JSON.stringify($json.draft_setup_data?.hebrew_patterns ?? {}) }}'::jsonb,\n  {{ $json.setup_completed }},\n  NOW(),\n  NOW()\n)\nON CONFLICT (business_id)\nDO UPDATE SET\n  business_model = EXCLUDED.business_model,\n  sales_goal = EXCLUDED.sales_goal,\n  conversation_strategy = EXCLUDED.conversation_strategy,\n  services = EXCLUDED.services,\n  persona = EXCLUDED.persona,\n  guardrails = EXCLUDED.guardrails,\n  hebrew_patterns = EXCLUDED.hebrew_patterns,\n  setup_completed = EXCLUDED.setup_completed,\n  committed_at = EXCLUDED.committed_at,\n  updated_at = NOW()\nRETURNING business_id, setup_completed;",
        "options": {}
