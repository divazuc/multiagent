    {
      "id": "3c964e34-30c9-4627-8d13-dda6ab69a6de",
      "typeVersion": 3.4,
      "position": [
        1600,
        200
      ],
      "name": "Build intro simulation prompt",
      "type": "n8n-nodes-base.set",
      "parameters": {
        "options": {},
        "assignments": {
          "assignments": [
            {
              "name": "prompt_type",
              "value": "intro",
              "type": "string"
            },
            {
              "name": "system_prompt",
              "value": "You are a simulation coordinator for a sales persona learning system. Your role is to help a business owner train their AI sales agent by simulating realistic lead conversations. You must ONLY respond in the same language the business owner uses. Do not explain that you are AI. Act as the coordinator presenting the exercise.",
              "type": "string"
            },
            {
              "name": "user_prompt",
              "value": "=Start the demo learning session for business_id: {{ $json.business_id }}. Greet the business owner warmly and explain that you will simulate 3-5 realistic lead conversations. Ask them to respond naturally \u2014 exactly as they would respond to a real potential customer. Tell them this will help train their sales agent to sound just like them. Begin with the first simulated lead message after they confirm they are ready. Keep your message short and natural.",
              "type": "string"
            },
            {
              "name": "next_stage",
              "value": "simulation",
              "type": "string"
            },
            {
              "name": "message",
              "value": "={{ $('Extract input fields').first().json.message }}",
              "type": "string"
            },
            {
              "name": "session_id",
              "value": "={{ $('Extract input fields').first().json.session_id }}",
              "type": "string"
            },
            {
              "name": "business_id",
              "value": "={{ $('Extract input fields').first().json.business_id }}",
              "type": "string"
            },
            {
              "name": "persona",
              "value": "={{ $('Extract input fields').first().json.persona }}",
              "type": "object"
            },
            {
              "name": "existing_hebrew_patterns",
              "value": "={{ $('Extract input fields').first().json.existing_hebrew_patterns }}",
              "type": "object"
            },
            {
              "name": "simulation_history",
              "value": "={{ $('Extract input fields').first().json.simulation_history }}",
              "type": "object"
            }
          ]
        }
      }
    },
    {
      "id": "74481ce7-8d3e-4283-99e8-87a78a69c6a6",
      "typeVersion": 2,
      "position": [
        1900,
        200
      ],
      "name": "Build simulation prompt",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const input = $('Extract input fields').first().json;\nconst history = input.simulation_history || [];\nconst persona = input.persona || {};\nconst historyCount = history.length;\n\n// Determine which simulation scenario to present based on history length\nconst scenarios = [\n  \"Hi, I saw your ad. What exactly do you offer?\",\n  \"How much does it cost? I want a quick price.\",\n  \"I'm comparing a few options right now, why should I pick you?\",\n  \"I'm not sure I need this right now, maybe in a few months.\",\n  \"Can I speak to someone? I have a few detailed questions.\"\n];\n\nconst scenarioIndex = Math.floor(historyCount / 2) % scenarios.length;\nconst simulatedLeadMessage = scenarios[scenarioIndex];\n\nconst historyText = history.map(h => `${h.role}: ${h.content}`).join('\\n');\n\nreturn [{\n  json: {\n    prompt_type: 'simulation',\n    system_prompt: `You are a simulation coordinator presenting realistic lead messages to a business owner. Present the next simulated lead message clearly, labeling it as \"Simulated Lead:\". Then wait for the business owner's reply. Do not add commentary. Keep it natural. Persona context: ${JSON.stringify(persona)}`,\n    user_prompt: `Conversation so far:\\n${historyText}\\n\\nBusiness owner's latest message: \"${input.message}\"\\n\\nNow present this next simulated lead message to the business owner:\\n\"${simulatedLeadMessage}\"\\n\\nFormat: Present only the simulated lead message naturally, labeled as Simulated Lead.`,\n    next_stage: scenarioIndex >= scenarios.length - 1 ? 'extraction' : 'simulation',\n    simulation_history: history,\n    message: input.message,\n    session_id: input.session_id,\n    business_id: input.business_id,\n    persona: persona,\n    existing_hebrew_patterns: input.existing_hebrew_patterns\n  }\n}];"
      }
    },
    {
      "id": "60551f91-ad01-4c17-a88b-672b3207ad22",
      "typeVersion": 2,
      "position": [
        2200,
        200
      ],
      "name": "Build extraction prompt",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const input = $('Extract input fields').first().json;\nconst history = input.simulation_history || [];\nconst persona = input.persona || {};\nconst patterns = input.existing_hebrew_patterns || {};\n\nconst historyText = history.map(h => `${h.role}: ${h.content}`).join('\\n');\n\nreturn [{\n  json: {\n    prompt_type: 'extraction',\n    system_prompt: `You are an expert sales communication analyst specializing in persona extraction. Analyze conversation samples from a business owner and extract their unique communication style, tone, phrasing patterns, sentence structures (including Hebrew patterns if present), objection handling style, and CTA approach. Return ONLY a valid JSON object \u2014 no markdown, no explanation.`,\n    user_prompt: `Here are the business owner's real responses during simulated lead conversations:\\n\\n${historyText}\\n\\nExisting persona: ${JSON.stringify(persona)}\\nExisting patterns: ${JSON.stringify(patterns)}\\n\\nExtract and return a JSON object with these fields:\\n{\\n  \"tone\": \"string describing tone\",\\n  \"wording_style\": \"string\",\\n  \"sentence_patterns\": [\"array of example sentence structures\"],\\n  \"hebrew_patterns\": { \"greetings\": [], \"closings\": [], \"objection_phrases\": [], \"cta_phrases\": [] },\\n  \"emoji_usage\": \"none|rare|moderate|frequent\",\\n  \"response_length\": \"short|medium|long\",\\n  \"objection_handling\": [\"array of actual phrases used\"],\\n  \"cta_style\": \"string describing how they push CTAs\",\\n  \"key_phrases\": [\"array of characteristic phrases\"]\n}`,\n    next_stage: 'complete',\n    message: input.message,\n    session_id: input.session_id,\n    business_id: input.business_id,\n    persona: persona,\n    existing_hebrew_patterns: patterns,\n    simulation_history: history\n  }\n}];"
      }
    },
    {
      "id": "2a30988c-9235-4acb-b885-e73ea29ad51e",
      "typeVersion": 3.4,
      "position": [
        2500,
        200
      ],
