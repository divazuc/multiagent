    },
    {
      "id": "d78e8555-c9e9-460d-ad88-313720f473f9",
      "typeVersion": 4.2,
      "position": [
        3100,
        200
      ],
      "name": "Call Anthropic for simulation",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 600,\n  \"system\": {{ JSON.stringify($json.system_prompt) }},\n  \"messages\": [\n    { \"role\": \"user\", \"content\": {{ JSON.stringify($json.user_prompt) }} }\n  ]\n}",
        "continueOnFail": true
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "O6dnMJBEHEOipCdX",
          "name": "ANTHROPIC_HTTP_HEADER_AUTH"
        }
      }
    },
    {
      "id": "b4e3c786-c317-4929-8709-25d3650596e8",
      "typeVersion": 2,
      "position": [
        3400,
        200
      ],
      "name": "Check Anthropic response",
      "type": "n8n-nodes-base.if",
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false
          },
          "conditions": [
            {
              "id": "check-content",
              "leftValue": "={{ $json.content && $json.content[0] && $json.content[0].text ? 'yes' : 'no' }}",
              "rightValue": "yes",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "a2f7ac89-eee3-4573-82c5-e4d487877293",
      "typeVersion": 3.4,
      "position": [
        3700,
        200
      ],
      "name": "Handle Anthropic error",
      "type": "n8n-nodes-base.set",
      "parameters": {
        "options": {},
        "assignments": {
          "assignments": [
            {
              "name": "status",
              "value": "error",
              "type": "string"
            },
            {
              "name": "result",
              "value": "={}",
              "type": "object"
            },
            {
              "name": "error",
              "value": "Anthropic API call failed during demo learning phase",
              "type": "string"
            }
          ]
        }
      }
    },
    {
      "id": "705a6606-7dc3-4b80-ae5d-174ed5f8d9af",
      "typeVersion": 2,
      "position": [
        4000,
        200
      ],
      "name": "Process Anthropic response",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const anthropicOutput = $input.first().json;\nconst rawText = anthropicOutput.content[0].text.trim();\nconst promptType = $('Determine learning stage action').first()?.json?.prompt_type || 'intro';\n\n// Determine which branch provided context \u2014 check all possible upstream nodes\nlet context = null;\nconst branchNodes = [\n  'Build intro simulation prompt',\n  'Build simulation prompt', \n  'Build extraction prompt',\n  'Build complete response',\n  'Build fallback response'\n];\n\nfor (const nodeName of branchNodes) {\n  try {\n    const item = $node[nodeName]?.json;\n    if (item) { context = item; break; }\n  } catch(e) {}\n}\n\nif (!context) {\n  return [{\n    json: {\n      status: 'error',\n      result: {},\n      error: 'Could not resolve branch context'\n    }\n  }];\n}\n\nconst promptTypeResolved = context.prompt_type || 'intro';\nconst nextStage = context.next_stage || 'intro';\n\nlet extractedPatterns = {};\nlet personaUpdated = false;\n\n// If extraction stage, try to parse the JSON from Claude\nif (promptTypeResolved === 'extraction') {\n  try {\n    const jsonMatch = rawText.match(/\\{[\\s\\S]*\\}/);\n    if (jsonMatch) {\n      extractedPatterns = JSON.parse(jsonMatch[0]);\n      personaUpdated = true;\n    }\n  } catch (e) {\n    extractedPatterns = { raw_extraction: rawText };\n    personaUpdated = false;\n  }\n}\n\n// Append the latest exchange to simulation history\nconst existingHistory = context.simulation_history || [];\nconst updatedHistory = [\n  ...existingHistory,\n  { role: 'owner', content: context.message || '' },\n  { role: 'coordinator', content: rawText }\n];\n\nreturn [{\n  json: {\n    status: 'success',\n    result: {\n      simulation_response: rawText,\n      extracted_patterns: extractedPatterns,\n      persona_updated: personaUpdated,\n      learning_stage: nextStage,\n      updated_simulation_history: updatedHistory\n    },\n    error: null\n  }\n}];"
      }
    },
    {
      "id": "1d685e77-894a-4285-821e-4dd46ec9f11a",
      "typeVersion": 2.5,
      "position": [
        4300,
        200
      ],
      "name": "Persist patterns to DB",
      "type": "n8n-nodes-base.postgres",
      "parameters": {
        "operation": "executeQuery",
        "query": "=UPDATE business_profiles\nSET\n  persona = persona || $1::jsonb,\n  hebrew_patterns = $2::jsonb,\n  updated_at = NOW()\nWHERE business_id = $3;",
        "additionalFields": {
          "queryParams": "={{ JSON.stringify($json.result.extracted_patterns) }}\n={{ JSON.stringify($json.result.extracted_patterns.hebrew_patterns || {}) }}\n={{ $('Extract input fields').first().json.business_id }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "O6dnMJBEHEOipCdX",
          "name": "Whatsapp_agent_DB"
        }
      },
      "continueOnFail": true
    },
    {
      "id": "f8d54bb1-a1d8-4ae8-b617-a75ba1ef4154",
      "typeVersion": 2.5,
      "position": [
        4600,
        200
      ],
      "name": "Update learning session stage",
      "type": "n8n-nodes-base.postgres",
      "parameters": {
        "operation": "executeQuery",
        "query": "=UPDATE sessions\nSET\n  current_learning_stage = $1,\n  simulation_history = $2::jsonb,\n  updated_at = NOW()\nWHERE session_id = $3;",
        "additionalFields": {
          "queryParams": "={{ $json.result.learning_stage }}\n={{ JSON.stringify($json.result.updated_simulation_history || []) }}\n={{ $('Extract input fields').first().json.session_id }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "O6dnMJBEHEOipCdX",
          "name": "Whatsapp_agent_DB"
        }
      },
      "continueOnFail": true
    },
    {
      "id": "b1ee4848-bc49-4655-a6b2-95c343707d34",
      "typeVersion": 3.4,
      "position": [
        4900,
        200
      ],
      "name": "Build final success output",
      "type": "n8n-nodes-base.set",
      "parameters": {
