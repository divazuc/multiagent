              "name": "user_prompt",
              "value": "=The learning phase is complete for business_id: {{ $('Extract input fields').first().json.business_id }}. Generate a short, warm completion message telling the business owner their agent is now trained on their style and is ready to handle real conversations. One sentence max.",
              "type": "string"
            },
            {
              "name": "next_stage",
