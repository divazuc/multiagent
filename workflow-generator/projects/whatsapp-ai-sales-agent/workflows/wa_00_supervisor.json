      "parameters": {
        "jsCode": "const norm = $('Normalize message').item.json.result || {};\nconst ctx = $('Load session and context').item.json.result || {};\nconst setupResult = $json.result || {};\nreturn [{ json: {\n  session_id: norm.session_id || '',\n  business_id: ctx.business_id || null,\n  action: setupResult.action || 'save_draft',\n  current_setup_stage: setupResult.next_setup_stage || 'collect_business_model',\n  draft_setup_data: setupResult.draft_setup_data || {},\n  setup_completed: setupResult.setup_completed || false\n}}];"
