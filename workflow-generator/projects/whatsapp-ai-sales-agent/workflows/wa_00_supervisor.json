      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT COALESCE(d.draft_setup_data, '{}'::jsonb) AS draft_setup_data, COALESCE(d.current_setup_stage, '') AS current_setup_stage FROM (SELECT 1) t LEFT JOIN setup_drafts d ON d.session_id = '{{ $json.result.session_id }}' LIMIT 1;",
