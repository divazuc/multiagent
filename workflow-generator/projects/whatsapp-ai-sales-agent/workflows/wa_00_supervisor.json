    {
      "parameters": {
        "jsCode": "const norm = $('Check normalize status').item.json.result || {};\nconst ctx = $('Check session status').item.json.result || {};\n\nconst draftRaw = $input.first().json;\nlet draftData = {};\ntry {\n  draftData = typeof draftRaw.draft_setup_data === 'string'\n    ? JSON.parse(draftRaw.draft_setup_data)\n    : (draftRaw.draft_setup_data || {});\n} catch(e) {}\n\nconst draftStage = draftRaw.current_setup_stage || '';\nconst rawStage = draftStage || ctx.current_stage || 'setup_start';\nconst setupStage = (!rawStage || rawStage === 'setup_start') ? 'collect_business_model' : rawStage;\n\nreturn [{ json: {\n  message: norm.message || '',\n  session_id: norm.session_id || '',\n  business_id: ctx.business_id || null,\n  current_setup_stage: setupStage,\n  draft_setup_data: draftData\n}}];"
