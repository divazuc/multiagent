    {
      "id": "c320a112-4891-482e-b403-b294f7e88fce",
      "typeVersion": 2.5,
      "position": [
        700,
        200
      ],
      "name": "Lookup session by session_id",
      "type": "n8n-nodes-base.postgres",
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT s.session_id, s.business_id, s.session_mode, s.current_stage, s.setup_completed, s.qualification_progress FROM (SELECT '{{ $json.session_id }}' AS sid) t LEFT JOIN sessions s ON s.session_id = t.sid LIMIT 1;",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "O6dnMJBEHEOipCdX",
          "name": "Whatsapp_agent_DB"
        }
      },
      "continueOnFail": true
    },
    {
      "id": "4416542d-238f-4ac6-b949-7f72ad97de91",
      "typeVersion": 2,
      "position": [
        1000,
        200
      ],
      "name": "Check session found",
      "type": "n8n-nodes-base.if",
      "parameters": {
        "conditions": {
          "options": {
