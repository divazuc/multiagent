    {
      "id": "96fc905d-d64e-4bb9-8d11-a2a80f6da022",
      "typeVersion": 2,
      "position": [
        2200,
        200
      ],
      "name": "Build context payload",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const session = $('Check session found').item.json;\nconst profile = $('Load business profile').item.json || {};\nconst historyItems = $('Load conversation history').all();\n\nconst conversationHistory = historyItems.map(i => ({\n  role: i.json.role,\n  content: i.json.content,\n  stage: i.json.stage,\n  created_at: i.json.created_at\n}));\n\nlet persona = {};\nlet guardrails = {};\nlet hebrewPatterns = {};\nlet services = [];\nlet qualificationProgress = {};\n\ntry { persona = typeof profile.persona === 'string' ? JSON.parse(profile.persona) : (profile.persona || {}); } catch(e) {}\ntry { guardrails = typeof profile.guardrails === 'string' ? JSON.parse(profile.guardrails) : (profile.guardrails || {}); } catch(e) {}\ntry { hebrewPatterns = typeof profile.hebrew_patterns === 'string' ? JSON.parse(profile.hebrew_patterns) : (profile.hebrew_patterns || {}); } catch(e) {}\ntry { services = typeof profile.services === 'string' ? JSON.parse(profile.services) : (profile.services || []); } catch(e) {}\ntry { qualificationProgress = typeof session.qualification_progress === 'string' ? JSON.parse(session.qualification_progress) : (session.qualification_progress || {}); } catch(e) {}\n\nconst allFields = ['need','scope','budget','timeline','urgency'];\nconst missingQualificationData = allFields.filter(f => !qualificationProgress[f]);\n\nreturn [{ json: {\n  business_id: session.business_id,\n  session_mode: session.session_mode || 'live_mode',\n  setup_completed: session.setup_completed || false,\n  current_stage: session.current_stage || 'start',\n  business_profile: {\n    business_name: profile.business_name,\n    business_model: profile.business_model,\n    sales_goal: profile.sales_goal,\n    conversation_strategy: profile.conversation_strategy,\n    services: services,\n    decision_logic: profile.decision_logic,\n    key_questions: profile.key_questions,\n    objection_handling: profile.objection_handling\n  },\n  persona,\n  guardrails,\n  hebrew_patterns: hebrewPatterns,\n  conversation_history: conversationHistory,\n  missing_qualification_data: missingQualificationData\n}}];"
      }
    },
    {
