      ],
      "name": "Load business profile",
      "type": "n8n-nodes-base.postgres",
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT bp.business_id, bp.business_name, bp.business_model, bp.sales_goal, bp.conversation_strategy, bp.services, bp.decision_logic, bp.key_questions, bp.objection_handling, bp.persona, bp.guardrails, bp.hebrew_patterns FROM business_profiles bp WHERE bp.business_id = '{{ $('Check session found').item.json.business_id }}' LIMIT 1;",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "O6dnMJBEHEOipCdX",
          "name": "Whatsapp_agent_DB"
        }
      },
      "continueOnFail": true
    },
    {
      "id": "053bfbce-ab62-457a-b864-ae044582dfed",
      "typeVersion": 2.5,
      "position": [
        1600,
        200
      ],
      "name": "Load conversation history",
      "type": "n8n-nodes-base.postgres",
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT c.role, c.content, c.stage, c.created_at FROM conversations c WHERE c.session_id = '{{ $('Check session found').item.json.session_id }}' ORDER BY c.created_at ASC LIMIT 50;",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "O6dnMJBEHEOipCdX",
          "name": "Whatsapp_agent_DB"
        }
      },
      "continueOnFail": true
    },
    {
      "id": "1b32f70d-4939-43cd-83c9-5d99d30a4e0f",
      "typeVersion": 3,
      "position": [
        1900,
        200
      ],
      "name": "Merge DB results",
