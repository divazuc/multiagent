    {
      "id": "7e601024-f3a3-44ab-a0ae-73b636f952aa",
      "typeVersion": 2,
      "position": [
        700,
        200
      ],
      "name": "Validate required fields",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst required = ['session_id', 'business_id', 'user_message', 'agent_response', 'stage'];\nconst missing = required.filter(f => !d[f]);\nif (missing.length > 0) {\n  return [{ json: { valid: false, missing_fields: missing } }];\n}\nreturn [{ json: { valid: true, missing_fields: [] } }];"
      }
    },
    {
      "id": "3aed29fe-600a-4cf2-ab78-c07e557ed060",
      "typeVersion": 2,
      "position": [
        1000,
        200
      ],
      "name": "Is input valid?",
      "type": "n8n-nodes-base.if",
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "valid_check",
              "leftValue": "={{ $json.valid }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "754a3e7e-474d-4726-b533-f649fa2af5ef",
      "typeVersion": 2.5,
      "position": [
        1300,
        200
      ],
      "name": "Save conversation message",
      "type": "n8n-nodes-base.postgres",
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO conversation_messages (\n  session_id,\n  business_id,\n  user_message,\n  agent_response,\n  stage,\n  action,\n  qualification_progress,\n  cta_triggered,\n  escalate,\n  escalation_reason,\n  language,\n  created_at\n) VALUES (\n  '{{ $('Receive sub-workflow input').item.json.session_id }}',\n  '{{ $('Receive sub-workflow input').item.json.business_id }}',\n  '{{ $('Receive sub-workflow input').item.json.user_message.replace(/'/g, \"''\") }}',\n  '{{ $('Receive sub-workflow input').item.json.agent_response.replace(/'/g, \"''\") }}',\n  '{{ $('Receive sub-workflow input').item.json.stage }}',\n  '{{ $('Receive sub-workflow input').item.json.action }}',\n  '{{ JSON.stringify($('Receive sub-workflow input').item.json.qualification_progress || {}) }}'::jsonb,\n  {{ $('Receive sub-workflow input').item.json.cta_triggered ? 'true' : 'false' }},\n  {{ $('Receive sub-workflow input').item.json.escalate ? 'true' : 'false' }},\n  '{{ ($('Receive sub-workflow input').item.json.escalation_reason || '').replace(/'/g, \"''\") }}',\n  '{{ $('Receive sub-workflow input').item.json.language || 'en' }}',\n  NOW()\n)\nRETURNING id;",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "O6dnMJBEHEOipCdX",
          "name": "Whatsapp_agent_DB"
        }
      },
      "continueOnFail": true
    },
    {
      "id": "6520a1dc-8d7d-434c-87ae-d940b71e6b68",
      "typeVersion": 2.5,
      "position": [
        1600,
        200
      ],
      "name": "Update session state",
      "type": "n8n-nodes-base.postgres",
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE sessions\nSET\n  current_stage = '{{ $('Receive sub-workflow input').item.json.stage }}',\n  last_message_at = NOW(),\n  cta_triggered = {{ $('Receive sub-workflow input').item.json.cta_triggered ? 'true' : 'false' }},\n  escalate = {{ $('Receive sub-workflow input').item.json.escalate ? 'true' : 'false' }},\n  qualification_progress = '{{ JSON.stringify($('Receive sub-workflow input').item.json.qualification_progress || {}) }}'::jsonb\nWHERE session_id = '{{ $('Receive sub-workflow input').item.json.session_id }}'\n  AND session_mode = 'live_mode'\nRETURNING session_id, session_mode;",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "O6dnMJBEHEOipCdX",
          "name": "Whatsapp_agent_DB"
        }
      },
      "continueOnFail": true
    },
    {
      "id": "66c8dbba-1de4-4040-8f79-aee565661ea0",
      "typeVersion": 2,
      "position": [
        1900,
        200
      ],
      "name": "Check DB errors",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const msgResult = $('Save conversation message').first()?.json;\nconst sessionResult = $('Update session state').first()?.json;\n\nconst msgError = msgResult?.error || (Array.isArray(msgResult) && msgResult.length === 0);\nconst sessionError = sessionResult?.error;\n\nif (msgError) {\n  return [{ json: {\n    has_error: true,\n    error_source: 'conversation_message_insert',\n    error_detail: msgResult?.error || 'No rows returned from insert'\n  }}];\n}\n\nreturn [{ json: {\n  has_error: false,\n  message_id: Array.isArray(msgResult) ? msgResult[0]?.id : msgResult?.id,\n  session_updated: !sessionError && sessionResult !== null\n}}];"
      }
    },
    {
      "id": "0c708ae2-9c48-4e72-bbe8-85895001decf",
