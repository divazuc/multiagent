    {
      "id": "eb82b7ef-224c-42cd-95fe-8bfb14be6bc3",
      "typeVersion": 2,
      "position": [
        3700,
        200
      ],
      "name": "Build draft setup data",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const inputs = $('Extract setup inputs').item.json;\nconst apiResponse = $input.first().json;\n\n// Extract AI text from Anthropic API response\nlet aiText = '';\nif (Array.isArray(apiResponse.content)) {\n  aiText = apiResponse.content[0]?.text || '';\n} else if (typeof apiResponse.text === 'string') {\n  aiText = apiResponse.text;\n}\n\n// Parse JSON from AI text (handle markdown code blocks)\nlet aiJson = {};\ntry {\n  const cleaned = aiText.replace(/```json\\s*/g, '').replace(/```\\s*/g, '').trim();\n  aiJson = JSON.parse(cleaned);\n} catch(e) {\n  const match = aiText.match(/\\{[\\s\\S]*\\}/);\n  if (match) {\n    try { aiJson = JSON.parse(match[0]); } catch(e2) {}\n  }\n}\n\nconst currentDraft = { ...(inputs.draft_setup_data || {}) };\nif (aiJson.extracted_value) {\n  currentDraft[inputs.current_setup_stage] = aiJson.extracted_value;\n}\nif (!currentDraft.persona) currentDraft.persona = {};\nif (!currentDraft.guardrails) currentDraft.guardrails = {};\n\nreturn [{json: {\n  session_id: inputs.session_id || '',\n  business_id: inputs.business_id || null,\n  current_setup_stage: inputs.current_setup_stage || 'collect_business_model',\n  next_setup_stage: aiJson.next_setup_stage || inputs.current_setup_stage || 'collect_business_model',\n  setup_response: aiJson.setup_response || '',\n  action: aiJson.action || 'save_draft',\n  setup_completed: false,\n  draft_setup_data: currentDraft\n}}];"
      }
    },
