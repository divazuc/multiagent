        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 1024,\n  \"system\": \"You are a business setup assistant reviewing a completed onboarding configuration. Present a clean, concise summary organized by section: Business Model, Sales Goal, Conversation Strategy, Services, Persona, Guardrails. End with a clear confirmation question.\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Review and present the setup data for confirmation:\\n\\nBusiness ID: {{ $json.business_id || 'N/A' }}\\nSession ID: {{ $json.session_id || 'N/A' }}\\nStage: {{ $json.current_setup_stage }}\\n\\nDraft Setup Data:\\n{{ JSON.stringify($json.draft_setup_data || {}, null, 2) }}\\n\\nUser message: {{ $json.message || '' }}\"\n    }\n  ]\n}",
