        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 1024,\n  \"system\": \"You are a guided business onboarding assistant. Collect the business model type. Ask ONE question at a time. Be short and human. Map to: service | product | subscription | booking | other. Respond in the user's language.\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Stage: collect_business_model\\n\\nDraft so far: {{ JSON.stringify($json.draft_setup_data || {}) }}\\n\\nMessage: {{ $json.message || '' }}\\n\\nReturn ONLY JSON: {\\\"setup_response\\\": \\\"<msg>\\\", \\\"next_setup_stage\\\": \\\"collect_sales_goal\\\", \\\"action\\\": \\\"save_draft\\\", \\\"extracted_value\\\": \\\"<service|product|subscription|booking|other|null>\\\", \\\"confirmed\\\": false}\"\n    }\n  ]\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        },
        "continueOnFail": true
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "O6dnMJBEHEOipCdX",
          "name": "ANTHROPIC_HTTP_HEADER_AUTH"
        }
      }
